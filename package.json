{
  "name": "x-engagement-reply-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone X (Twitter) engagement reply agent: targeted-author polling, Soofi article matching, prompt-driven recommended replies, and Asana approval tasking.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "refresh:status": "tsx scripts/refresh-status.ts",
    "live:e2e": "tsx scripts/live-e2e.ts"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.1",
    "@ai-sdk/provider": "^4.0.0",
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/credential-providers": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@soofi-xyz/chat-adapter-asana": "^0.2.0",
    "ai": "^7.0.3",
    "gray-matter": "^4.0.3",
    "langsmith": "^0.7.12",
    "next": "^15.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
