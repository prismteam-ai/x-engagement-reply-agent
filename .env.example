# ---- LLM provider (provider-agnostic via Vercel AI SDK) ----
# modelId is set in config/settings.yaml (e.g. openai/gpt-4.1-mini or bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0)
OPENAI_API_KEY=
# For Bedrock models (modelId starts with "bedrock/") use standard AWS creds:
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- investors-mcp (read-only RAG) ----
# Public, no token required today. Override only if hardened later.
MCP_URL=https://investors-mcp.vercel.app/mcp
# MCP_READ_TOKEN=

# ---- X / Twitter API v2 (live driver only; fixture driver needs nothing) ----
X_BEARER_TOKEN=

# ---- Asana ----
ASANA_PERSONAL_ACCESS_TOKEN=

# ---- LangSmith (LLM run tracing) ----
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=x-engagement-reply-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Runtime ----
# X source driver: "fixture" (default, offline) or "live"
X_DRIVER=fixture
LOG_LEVEL=info

# ---- State store ----
# "file" (default, local JSON at data/state.json) or "dynamo" (DynamoDB, prod).
STATE_STORE=file
# Required when STATE_STORE=dynamo — the DynamoDB table name (CDK output, or
# "AgentState" for the docker-compose dev stack).
# AGENT_STATE_TABLE=AgentState
# Optional: TTL (days) for processed/tasked dedupe keys. Default 90.
# STATE_TTL_DAYS=90
# Point at DynamoDB Local (docker-compose). Leave unset in AWS.
# DYNAMODB_ENDPOINT=http://localhost:8000

# ---- Secrets (Lambda only) ----
# In AWS, the function reads its credentials from one JSON secret in Secrets
# Manager instead of this file. Set by the CDK stack; leave unset locally.
# AGENT_SECRETS_ARN=
