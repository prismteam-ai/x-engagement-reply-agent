# X Engagement Reply Agent — environment.
#
# EVERYTHING here is OPTIONAL. With no .env at all the agent runs fully:
#   - article matching is REAL (the hosted MCP needs no auth),
#   - X polling uses deterministic fixtures,
#   - reply drafting uses the offline deterministic generator,
#   - Asana task creation writes preview JSON to .out/asana/.
# Provide a credential below to swap the matching adapter to its live version.

# ── Knowledge retrieval (MCP) ───────────────────────────────────────────────
# Defaults to the hosted, open, read-only investors-mcp endpoint.
MCP_URL=https://investors-mcp.vercel.app/mcp
# MCP_READ_TOKEN=                 # only if the operator later enables read auth

# ── X / Twitter API (activates LiveXClient) ─────────────────────────────────
# X_BEARER_TOKEN=
# X_MONITOR_X_API_ORIGIN=https://api.twitter.com
# X_FORCE_FIXTURE=1               # force fixtures even if a token is set

# ── Asana (activates LiveAsanaClient) ───────────────────────────────────────
# ASANA_ACCESS_TOKEN=
# ASANA_PROJECT_GID=
# ASANA_SECTION_GID=
# ASANA_WORKSPACE_GID=
# ASANA_ASSIGNEE_GID=
# ASANA_ARTICLE_THRESHOLD_ASSIGNEE_GID=
# ASANA_SIMILARITY_SCORE_CUSTOM_FIELD_GID=
# ASANA_TASK_SIMILARITY_SCORE_CUSTOM_FIELD_GID=
# ASANA_SUBTASK_SIMILARITY_SCORE_CUSTOM_FIELD_GID=

# ── LLM reply drafting (activates LlmReplyGenerator) ────────────────────────
# Set modelId in config/settings.yaml to openai/* or anthropic/* and supply the key.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Agent Network Platform (run reporting) ──────────────────────────────────
# PLATFORM_URL=http://localhost:3100

# ── Misc ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info                  # debug | info | warn | error
# LOG_JSON=1                      # suppress the pretty stderr line, JSON only
# STATE_DIR=.state
# OUT_DIR=.out
