# X Engagement Reply Agent — environment variables
# Placeholders only. NEVER commit real secrets. Copy to .env.local and fill in.
#
# This cred-free slice (config-as-code + prompts) does NOT read any of these.
# They are listed here so the full agent has a single source of truth.

# ---------------------------------------------------------------------------
# LLM provider — Amazon Bedrock (reply generation)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
# Bedrock API key (bearer token). When set, the AI SDK uses Bearer-token auth
# instead of AWS SigV4/IAM. This is the supported auth path for this account.
AWS_BEARER_TOKEN_BEDROCK=
# SigV4/IAM credentials are an alternative if no bearer token is present.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Bedrock model id / cross-region inference profile used for reply drafting,
# e.g. us.anthropic.claude-opus-4-6-v1 (overrides config/settings.yaml modelId).
BEDROCK_MODEL_ID=
# Optional: max concurrent Bedrock calls during the per-slot fan-out (default 1,
# fully serialized — avoids on-demand 429s so showcase/live runs come out all-real).
# Raise it deliberately when throughput matters more than 429-avoidance.
BEDROCK_MAX_CONCURRENCY=1
# Optional: retries (exponential backoff) for a throttled (429) Bedrock call so
# per-slot drafts come out real instead of placeholders (default 4).
BEDROCK_MAX_RETRIES=4
# Optional: per-call request timeout in ms; a hung Bedrock call aborts and is
# retried as a transient failure (default 30000).
BEDROCK_REQUEST_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Observability — LangSmith (traceable LLM runs) — OPTIONAL
# Tracing activates only when LANGSMITH_API_KEY is present; absent, the agent
# runs normally with tracing disabled (no failure).
# ---------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=xatu-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# ---------------------------------------------------------------------------
# Asana — approval task creation
# ---------------------------------------------------------------------------
ASANA_PAT=
ASANA_PROJECT_GID=
ASANA_WORKSPACE_GID=
# Optional: place the created parent task into this section after creation. When unset, the task stays in the project's default location.
ASANA_SECTION_GID=
ASANA_DEFAULT_ASSIGNEE_GID=
ASANA_THRESHOLD_ASSIGNEE_GID=
ASANA_RAW_SIMILARITY_FIELD_GID=
ASANA_NORMALIZED_SIMILARITY_FIELD_GID=
ASANA_MAX_RETRIES=3
ASANA_REQUEST_TIMEOUT_MS=20000

# ---------------------------------------------------------------------------
# X (Twitter) — author polling
# ---------------------------------------------------------------------------
X_BEARER_TOKEN=
# Optional: retries (jittered exponential backoff) for a TRANSIENT X API failure
# (HTTP 5xx, request timeout, network error). 429/auth errors are NOT retried —
# they abort the run as designed (default 3).
X_MAX_RETRIES=3
# Optional: per-call X API request timeout in ms; a hung request aborts and is
# retried as a transient failure (default 15000).
X_REQUEST_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Runtime state — DynamoDB (polling cursors, cross-run dedupe, run snapshot)
#
# Single-table design: partition key `pk` (S), sort key `sk` (S),
# PAY_PER_REQUEST billing, TTL on `ttl` (N, epoch seconds). When DYNAMODB_TABLE
# is set AND the IAM creds below are present, state persists to DynamoDB (durable
# on Vercel's ephemeral FS). When DYNAMODB_TABLE is absent, the latest-run
# snapshot falls back to a local file under .data/ (local dev + tests).
#
# Uses the AWS IAM keys (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION
# above) — these are SEPARATE from the Bedrock bearer token.
# DYNAMODB_ENDPOINT / AWS_SESSION_TOKEN are optional overrides.
# ---------------------------------------------------------------------------
DYNAMODB_TABLE=xatu-agent-state

# ---------------------------------------------------------------------------
# Knowledge retrieval — hosted investors-mcp (read-only, no token required today)
# ---------------------------------------------------------------------------
INVESTORS_MCP_URL=https://investors-mcp.vercel.app/mcp
# Optional: retries (jittered exponential backoff) for a TRANSIENT MCP failure
# (HTTP 5xx, request timeout, transport/connection drop, network error) when the
# hosted server cold-starts or blips. A clear non-transient client error throws
# without retry; an exhausted budget throws (default 3).
INVESTORS_MCP_MAX_RETRIES=3
# Optional: per-call MCP request timeout in ms; a hung connect/query aborts and is
# retried as a transient failure (default 15000).
INVESTORS_MCP_REQUEST_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Trigger auth — required for any real-run/showcase invocation of /api/monitor-x
# A real run (?dryRun=false or ?showcase=true) must present this secret via
# `Authorization: Bearer <CRON_SECRET>` or `?key=<CRON_SECRET>`; otherwise 401.
# Vercel cron invocations carry this Bearer header automatically when set.
# The public dry-run snapshot probe (?dryRun=true) needs no secret.
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET=
